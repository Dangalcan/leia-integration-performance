# ── Core ─────────────────────────────────────────────────────────────────────

# leia-runner target URL
TARGET_HOST=http://localhost:9000

# Bearer token (matches RUNNER_KEY in leia-runner .env)
RUNNER_KEY=your-runner-key-here

# Path to session recordings (relative to project root or absolute)
SESSIONS_DIR=./sessions

# AI provider to use when creating LEIA instances
DEFAULT_PROVIDER=alma

# Cap user think time between exchanges (seconds)
MAX_THINK_TIME_SECONDS=120

# ── LEIA instance spec ────────────────────────────────────────────────────────

# Prefix for generated LEIA instance IDs
LEIA_INSTANCE_ID=leia-perf-test

# Optional: path to a JSON file overriding the built-in LEIA spec.
# Schema: { "leia_id", "description", "solution", "solution_format",
#            "evaluation_prompt" }
# Leave empty to use the built-in theater-ticket-platform spec.
LEIA_SPEC_FILE=

# ── Timing & resilience ───────────────────────────────────────────────────────

# Max gap (ms) between messages within a burst group
BURST_GAP_CAP_MS=5000

# HTTP request timeout in seconds (applied to all leia-runner calls)
REQUEST_TIMEOUT_SECONDS=60

# Max retries for send_message on 5xx / network errors (0 = no retries)
RETRY_MAX=2

# If true, continue session replay after a single failed message
# instead of aborting the whole session
CONTINUE_ON_MESSAGE_FAILURE=false

# ── Classification thresholds ─────────────────────────────────────────────────

# Sessions with exchange_count <= this value are classified as "short"
SHORT_MAX_EXCHANGES=12

# Sessions with exchange_count >= this value are classified as "long"
LONG_MIN_EXCHANGES=20

# ── Observability ─────────────────────────────────────────────────────────────

# Comma-separated percentiles reported in the console summary and JSON export
PERCENTILES=50,90,99

# If true, fire GET /api/v1/models before the test starts to verify connectivity
PREFLIGHT_CHECK=false

# Seconds to wait after a session creation failure before the next task starts.
# Prevents a tight failure loop DoSing the server when leia-runner is slow or
# temporarily overloaded. Default 2s keeps req rate ≤ 10 req/s with 20 users.
FAILURE_BACKOFF_SECONDS=2.0
